# ===== A) 실험 실행 관련 =====

# Runner / execution
MAX_CONCURRENCY=1
NUM_WORKERS=4

# Experiment cache identity
CVDC_CACHE_NAMESPACE=cvdc
CVDC_CACHE_VERSION=v1
CVDC_CODE_SALT=
CVDC_DATA_SALT=

# Runtime behavior
CVDC_REQUIRE_CUDA=1
RUNNER_ID=<github_id>
REUSE_ENABLED=true
GC_ENABLED=true
GC_KEEP_RECENT=1

# ===== B) 프로젝트 폴더/경로 관리 =====
ROOT_DIR=members/<github_id>
CONFIG_DIR=configs
DOCS_DIR=docs

DATA_DIR=data
CACHE_DIR=cache
RUNS_DIR=outputs
LOG_DIR=logs

# ===== C) 서비스/도구 연동 =====

# S3 upload
S3_BUCKET=
S3_PREFIX=cvdc
S3_DEDUP_BY_HASH=1
S3_DRY_RUN=0
S3_UPLOAD_WHITELIST=

# AWS credentials for boto3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2

# W&B auth/project
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=cv-doc-class
WANDB_MODE=disabled

# Slack notification
SLACK_NOTIFY=0
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Hugging Face
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=${HF_TOKEN}
HF_HOME=cache/huggingface
HF_HUB_CACHE=cache/huggingface/hub
TRANSFORMERS_CACHE=cache/huggingface/hub
HF_XET_HIGH_PERFORMANCE=1
